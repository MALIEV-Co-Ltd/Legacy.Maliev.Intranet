@page "/QuotationRequests/View"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IStringLocalizer<QuotationRequestView> Text
<PageTitle>@Text["PageTitle",Id??0]</PageTitle>
<MudContainer MaxWidth="MaxWidth.Large">@if(loading){<MudProgressLinear Indeterminate="true"/>}else if(error is not null){<MudAlert Severity="Severity.Error">@error</MudAlert>}else if(detail is not null){<div class="d-flex justify-space-between mb-4"><MudText Typo="Typo.h4" HtmlTag="h1">@Text["Heading",detail.Request.Id]</MudText><MudButton Href="/QuotationRequests/Index">@Text["Back"]</MudButton></div>@if(notice is not null){<MudAlert Severity="Severity.Success" Class="mb-4">@notice</MudAlert>}<MudForm @ref="form" Model="edit"><MudGrid><MudItem xs="12" md="6"><MudTextField Label="@Text["FirstName"]" @bind-Value="edit.FirstName"/></MudItem><MudItem xs="12" md="6"><MudTextField Label="@Text["LastName"]" @bind-Value="edit.LastName"/></MudItem><MudItem xs="12" md="6"><MudTextField Label="@Text["Email"]" @bind-Value="edit.Email" InputType="InputType.Email"/></MudItem><MudItem xs="12" md="6"><MudTextField Label="@Text["Telephone"]" @bind-Value="edit.TelephoneNumber"/></MudItem><MudItem xs="12" md="6"><MudTextField Label="@Text["Company"]" @bind-Value="edit.CompanyName"/></MudItem><MudItem xs="12" md="6"><MudTextField Label="@Text["Country"]" @bind-Value="edit.Country"/></MudItem><MudItem xs="12"><MudTextField Label="@Text["Tax"]" @bind-Value="edit.TaxIdentification"/></MudItem><MudItem xs="12"><MudTextField Label="@Text["Message"]" @bind-Value="edit.Message" Lines="5"/></MudItem><MudItem xs="12"><MudTextField Label="@Text["Internal"]" @bind-Value="edit.InternalComment" Lines="4"/></MudItem><MudItem xs="12"><MudSelect T="bool?" Label="@Text["Status"]" @bind-Value="edit.Done" Required="true"><MudSelectItem T="bool?" Value="@((bool?)false)">@Text["Open"]</MudSelectItem><MudSelectItem T="bool?" Value="@((bool?)true)">@Text["Done"]</MudSelectItem></MudSelect></MudItem><MudItem xs="12"><MudButton OnClick="SaveAsync" Disabled="submitting" Variant="Variant.Filled">@Text["Save"]</MudButton></MudItem></MudGrid></MudForm><MudPaper Class="pa-4 mt-4"><MudText Typo="Typo.h5" HtmlTag="h2">@Text["Files"]</MudText>@if(detail.Files.Count==0){<MudText>@Text["NoFiles"]</MudText>}else{<MudList T="QuotationRequestFileItem">@foreach(var file in detail.Files){<MudListItem Value="file">@if(file.Uri is null){<MudText>@file.ObjectName</MudText>}else{<MudLink Href="@file.Uri.ToString()" Target="_blank">@file.ObjectName</MudLink>}</MudListItem>}</MudList>}</MudPaper>}</MudContainer>
@code{
 [SupplyParameterFromQuery(Name="id")]public int? Id{get;set;} private MudForm? form;private QuotationRequestDetail? detail;private Edit edit=new();private EmployeeSessionSummary? session;private bool loading=true,submitting;private string? error;private string? notice;
 protected override async Task OnParametersSetAsync()=>await LoadAsync();private async Task LoadAsync(){loading=true;error=null;if(Id is not>0){error=Text["InvalidId"];loading=false;return;}try{session=await Http.GetFromJsonAsync<EmployeeSessionSummary>("/bff/session");using var response=await Http.GetAsync($"/bff/quotation-requests/{Id}");if(response.StatusCode==HttpStatusCode.NotFound){error=Text["NotFound"];return;}if(!response.IsSuccessStatusCode){error=Text["Unavailable"];return;}detail=await response.Content.ReadFromJsonAsync<QuotationRequestDetail>();if(detail is null){error=Text["Invalid"];return;}edit=Edit.From(detail.Request);}catch(Exception ex)when(ex is HttpRequestException or System.Text.Json.JsonException){error=Text["Unavailable"];}finally{loading=false;}}
 private async Task SaveAsync(){if(detail is null||form is null||session?.CsrfToken is null)return;await form.ValidateAsync();if(!form.IsValid)return;using var request=new HttpRequestMessage(HttpMethod.Put,$"/bff/quotation-requests/{detail.Request.Id}"){Content=JsonContent.Create(edit.ToRequest())};request.Headers.Add("X-CSRF-TOKEN",session.CsrfToken);submitting=true;try{using var response=await Http.SendAsync(request);if(response.StatusCode==HttpStatusCode.Conflict){error=Text["Conflict"];return;}if(!response.IsSuccessStatusCode){error=Text["Unavailable"];return;}notice=Text["Saved"];await LoadAsync();}catch(HttpRequestException){error=Text["Unavailable"];}finally{submitting=false;}}
 private sealed class Edit{public string? FirstName{get;set;}public string? LastName{get;set;}public string? Email{get;set;}public string? TelephoneNumber{get;set;}public string? Country{get;set;}public string? CompanyName{get;set;}public string? TaxIdentification{get;set;}public string? Message{get;set;}public string? InternalComment{get;set;}public bool? Done{get;set;}public DateTime? ModifiedDate{get;set;}public static Edit From(QuotationRequestItem x)=>new(){FirstName=x.FirstName,LastName=x.LastName,Email=x.Email,TelephoneNumber=x.TelephoneNumber,Country=x.Country,CompanyName=x.CompanyName,TaxIdentification=x.TaxIdentification,Message=x.Message,InternalComment=x.InternalComment,Done=x.Done,ModifiedDate=x.ModifiedDate};public QuotationRequestUpdate ToRequest()=>new(FirstName,LastName,Email,TelephoneNumber,Country,CompanyName,TaxIdentification,Message,InternalComment,Done,ModifiedDate);}
}
