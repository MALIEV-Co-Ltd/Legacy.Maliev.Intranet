<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly" AdditionalAssemblies="@lazyAssemblies" OnNavigateAsync="LoadFeatureAssemblyAsync">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="routeData" DefaultLayout="@typeof(Layout.MainLayout)">
                <NotAuthorized>
                    <LoginRedirect />
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(Layout.MainLayout)">
                <MudAlert Severity="Severity.Warning">This employee route has not been migrated yet.</MudAlert>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code {
    private readonly List<System.Reflection.Assembly> lazyAssemblies = [];
    private readonly HashSet<string> loadedFeatureAssemblies = new(StringComparer.Ordinal);

    [Inject] private Microsoft.AspNetCore.Components.WebAssembly.Services.LazyAssemblyLoader AssemblyLoader { get; set; } = default!;

    private async Task LoadFeatureAssemblyAsync(Microsoft.AspNetCore.Components.Routing.NavigationContext context)
    {
        var assemblyName = context.Path.StartsWith("Materials/", StringComparison.OrdinalIgnoreCase)
            ? "Legacy.Maliev.Intranet.Client.Features.Catalog.wasm"
            : context.Path.StartsWith("Customers/", StringComparison.OrdinalIgnoreCase)
                ? "Legacy.Maliev.Intranet.Client.Features.Customers.wasm"
                : context.Path.StartsWith("Employees/", StringComparison.OrdinalIgnoreCase)
                    ? "Legacy.Maliev.Intranet.Client.Features.Employees.wasm"
                    : context.Path.StartsWith("Orders/", StringComparison.OrdinalIgnoreCase)
                        ? "Legacy.Maliev.Intranet.Client.Features.Orders.wasm"
                        : null;
        if (assemblyName is not null && loadedFeatureAssemblies.Add(assemblyName))
        {
            context.CancellationToken.ThrowIfCancellationRequested();
            lazyAssemblies.AddRange(await AssemblyLoader.LoadAssembliesAsync(
                [assemblyName]));
            context.CancellationToken.ThrowIfCancellationRequested();
        }
    }
}
