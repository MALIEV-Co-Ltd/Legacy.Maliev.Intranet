<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly" AdditionalAssemblies="@lazyAssemblies" OnNavigateAsync="LoadFeatureAssemblyAsync">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="routeData" DefaultLayout="@typeof(Layout.MainLayout)">
                <NotAuthorized>
                    <LoginRedirect />
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(Layout.MainLayout)">
                <MudAlert Severity="Severity.Warning">This employee route has not been migrated yet.</MudAlert>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code {
    private readonly List<System.Reflection.Assembly> lazyAssemblies = [];

    [Inject] private Microsoft.AspNetCore.Components.WebAssembly.Services.LazyAssemblyLoader AssemblyLoader { get; set; } = default!;

    private async Task LoadFeatureAssemblyAsync(Microsoft.AspNetCore.Components.Routing.NavigationContext context)
    {
        if (context.Path.StartsWith("Materials/", StringComparison.OrdinalIgnoreCase) && lazyAssemblies.Count == 0)
        {
            context.CancellationToken.ThrowIfCancellationRequested();
            lazyAssemblies.AddRange(await AssemblyLoader.LoadAssembliesAsync(
                ["Legacy.Maliev.Intranet.Client.Features.Catalog.wasm"]));
            context.CancellationToken.ThrowIfCancellationRequested();
        }
    }
}
