@page "/Employees/ForgotPassword"
@attribute [AllowAnonymous]
@inject HttpClient Http
@inject IStringLocalizer<EmployeeForgotPassword> Text

<PageTitle>@Text["PageTitle"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="employee-recovery">
    <MudPaper Class="pa-6" Elevation="1">
        <MudText Typo="Typo.h4" HtmlTag="h1" Class="mb-2">@Text["Heading"]</MudText>
        <MudText Typo="Typo.body1" Class="mb-6">@Text["Introduction"]</MudText>

        @if (!string.IsNullOrWhiteSpace(notice))
        {
            <MudAlert Severity="@noticeSeverity" Class="mb-4" aria-live="polite">@notice</MudAlert>
        }

        @if (submitting)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
        }

        <MudForm @ref="form" @bind-IsValid="formValid">
            <MudTextField T="string"
                          @bind-Value="email"
                          Label="@Text["Email"]"
                          InputType="InputType.Email"
                          autocomplete="email"
                          Required="true"
                          RequiredError="@Text["EmailRequired"]"
                          Disabled="submitting"
                          FullWidth="true"
                          Class="mb-4" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       ButtonType="ButtonType.Button"
                       OnClick="SubmitAsync"
                       Disabled="submitting"
                       FullWidth="true">
                @Text["Submit"]
            </MudButton>
        </MudForm>
        <MudButton Href="/Login" Variant="Variant.Text" Class="mt-3">@Text["BackToLogin"]</MudButton>
    </MudPaper>
</MudContainer>

@code {
    private MudForm? form;
    private bool formValid;
    private bool submitting;
    private string email = string.Empty;
    private string? notice;
    private Severity noticeSeverity = Severity.Info;

    private async Task SubmitAsync()
    {
        if (submitting || form is null) return;
        await form.ValidateAsync();
        if (!formValid) return;

        submitting = true;
        notice = null;
        try
        {
            var csrf = await GetCsrfAsync();
            if (csrf is null) { ShowError(Text["Unavailable"]); return; }
            using var request = new HttpRequestMessage(HttpMethod.Post, "/bff/employee-recovery/password-reset/request")
            {
                Content = JsonContent.Create(new EmployeeRecoveryEmailRequest(email.Trim())),
            };
            request.Headers.Add("X-CSRF-TOKEN", csrf);
            using var response = await Http.SendAsync(request);
            if (response.StatusCode == HttpStatusCode.Accepted)
            {
                noticeSeverity = Severity.Success;
                notice = Text["Accepted"];
                return;
            }

            ShowError(response.StatusCode == HttpStatusCode.TooManyRequests
                ? Text["RateLimited"]
                : Text["Unavailable"]);
        }
        catch (Exception exception) when (
            exception is HttpRequestException or TaskCanceledException or System.Text.Json.JsonException)
        {
            ShowError(Text["Unavailable"]);
        }
        finally { submitting = false; }
    }

    private async Task<string?> GetCsrfAsync()
    {
        using var response = await Http.GetAsync("/bff/session");
        if (!response.IsSuccessStatusCode) return null;
        return (await response.Content.ReadFromJsonAsync<EmployeeSessionSummary>())?.CsrfToken;
    }

    private void ShowError(string message)
    {
        noticeSeverity = Severity.Error;
        notice = message;
    }
}
