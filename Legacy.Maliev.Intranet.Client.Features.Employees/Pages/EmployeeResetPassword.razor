@page "/Employees/ResetPassword"
@attribute [AllowAnonymous]
@inject HttpClient Http
@inject IStringLocalizer<EmployeeResetPassword> Text

<PageTitle>@Text["PageTitle"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="employee-recovery">
    <MudPaper Class="pa-6" Elevation="1">
        <MudText Typo="Typo.h4" HtmlTag="h1" Class="mb-2">@Text["Heading"]</MudText>
        <MudText Typo="Typo.body1" Class="mb-6">@Text["Introduction"]</MudText>

        @if (!HasValidAction)
        {
            <MudAlert Severity="Severity.Error" aria-live="assertive">@Text["InvalidLink"]</MudAlert>
            <MudButton Href="/Employees/ForgotPassword" Variant="Variant.Text" Class="mt-3">@Text["RequestNewLink"]</MudButton>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(notice))
            {
                <MudAlert Severity="@noticeSeverity" Class="mb-4" aria-live="polite">@notice</MudAlert>
            }
            @if (submitting)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
            }
            <MudForm @ref="form" @bind-IsValid="formValid">
                <MudTextField T="string" @bind-Value="password" Label="@Text["Password"]" InputType="InputType.Password"
                              autocomplete="new-password" Required="true" RequiredError="@Text["PasswordRequired"]"
                              Disabled="submitting" FullWidth="true" Class="mb-3" />
                <MudTextField T="string" @bind-Value="confirmPassword" Label="@Text["ConfirmPassword"]" InputType="InputType.Password"
                              autocomplete="new-password" Required="true" RequiredError="@Text["ConfirmPasswordRequired"]"
                              Disabled="submitting" FullWidth="true" Class="mb-4" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Button"
                           OnClick="SubmitAsync" Disabled="submitting" FullWidth="true">@Text["Submit"]</MudButton>
            </MudForm>
            @if (completed)
            {
                <MudButton Href="/Login" Variant="Variant.Text" Class="mt-3">@Text["SignIn"]</MudButton>
            }
        }
    </MudPaper>
</MudContainer>

@code {
    private MudForm? form;
    private bool formValid;
    private bool submitting;
    private bool completed;
    private string password = string.Empty;
    private string confirmPassword = string.Empty;
    private string? notice;
    private Severity noticeSeverity = Severity.Info;

    [SupplyParameterFromQuery(Name = "email")] public string? Email { get; set; }
    [SupplyParameterFromQuery(Name = "token")] public string? Token { get; set; }
    private bool HasValidAction => !string.IsNullOrWhiteSpace(Email) && !string.IsNullOrWhiteSpace(Token);

    private async Task SubmitAsync()
    {
        if (submitting || completed || form is null || !HasValidAction) return;
        await form.ValidateAsync();
        if (!formValid) return;
        if (!string.Equals(password, confirmPassword, StringComparison.Ordinal))
        {
            ShowError(Text["Mismatch"]);
            return;
        }

        submitting = true;
        notice = null;
        var submittedPassword = password;
        password = string.Empty;
        confirmPassword = string.Empty;
        try
        {
            var csrf = await GetCsrfAsync();
            if (csrf is null) { ShowError(Text["Unavailable"]); return; }
            using var request = new HttpRequestMessage(HttpMethod.Post, "/bff/employee-recovery/password-reset/complete")
            {
                Content = JsonContent.Create(new EmployeePasswordResetRequest(Email!, Token!, submittedPassword, submittedPassword)),
            };
            request.Headers.Add("X-CSRF-TOKEN", csrf);
            using var response = await Http.SendAsync(request);
            submittedPassword = string.Empty;
            if (response.StatusCode == HttpStatusCode.NoContent)
            {
                completed = true;
                noticeSeverity = Severity.Success;
                notice = Text["Completed"];
                return;
            }

            ShowError(response.StatusCode switch
            {
                HttpStatusCode.BadRequest => Text["InvalidLink"],
                HttpStatusCode.TooManyRequests => Text["RateLimited"],
                _ => Text["Unavailable"],
            });
        }
        catch (Exception exception) when (
            exception is HttpRequestException or TaskCanceledException or System.Text.Json.JsonException)
        {
            ShowError(Text["Unavailable"]);
        }
        finally
        {
            submittedPassword = string.Empty;
            submitting = false;
        }
    }

    private async Task<string?> GetCsrfAsync()
    {
        using var response = await Http.GetAsync("/bff/session");
        if (!response.IsSuccessStatusCode) return null;
        return (await response.Content.ReadFromJsonAsync<EmployeeSessionSummary>())?.CsrfToken;
    }

    private void ShowError(string message)
    {
        noticeSeverity = Severity.Error;
        notice = message;
    }
}
