@page
@model Legacy.Maliev.Intranet.Pages.Customers.CreateModel
@{
    ViewData["Title"] = "Create customer";
}
<section class="panel">
    <p class="eyebrow">Customer profile and account</p>
    <h1>Create customer</h1>
    <p>The password is sent only to AuthService in an encrypted server-to-server request and is never placed in a URL.</p>
    <form method="post" class="customer-form">
        <div asp-validation-summary="ModelOnly" class="validation"></div>
        <label>First name <input asp-for="Input.FirstName" autocomplete="given-name" /></label>
        <span asp-validation-for="Input.FirstName" class="validation"></span>
        <label>Last name <input asp-for="Input.LastName" autocomplete="family-name" /></label>
        <span asp-validation-for="Input.LastName" class="validation"></span>
        <label>Email <input asp-for="Input.Email" autocomplete="email" /></label>
        <span asp-validation-for="Input.Email" class="validation"></span>
        <label>Password <input asp-for="Input.Password" autocomplete="new-password" /></label>
        <span asp-validation-for="Input.Password" class="validation"></span>
        <label>Confirm password <input asp-for="Input.ConfirmPassword" autocomplete="new-password" /></label>
        <span asp-validation-for="Input.ConfirmPassword" class="validation"></span>
        <label>Telephone <input asp-for="Input.Telephone" autocomplete="tel" /></label>
        <label>Mobile <input asp-for="Input.Mobile" /></label>
        <label>Fax <input asp-for="Input.Fax" /></label>
        <label>Date of birth <input asp-for="Input.DateOfBirth" /></label>
        <button type="submit">Create customer</button>
    </form>
</section>
