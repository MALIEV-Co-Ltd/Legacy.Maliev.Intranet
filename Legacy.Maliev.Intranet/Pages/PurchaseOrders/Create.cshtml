@page
@model Legacy.Maliev.Intranet.Pages.PurchaseOrders.CreateModel
@{ ViewData["Title"] = "Create purchase order"; }
<section class="panel"><p class="eyebrow">Procurement</p><h1>Create purchase order</h1><form method="post" class="purchase-order-form"><div asp-validation-summary="All" class="validation"></div>
<fieldset><legend>Supplier</legend><label>Supplier <select asp-for="Input.SupplierId"><option value="">Select a supplier</option>@foreach(var value in Model.Suppliers){<option value="@value.Id">@value.Name</option>}</select></label><label>Contact <input asp-for="Input.SupplierContactPerson" /></label></fieldset>
<div class="form-columns"><fieldset><legend>Shipping</legend><label>Company <input asp-for="Input.ShippingCompanyName" /></label><label>Address <select asp-for="Input.ShippingAddressId"><option value="">Select an address</option>@foreach(var value in Model.Addresses){<option value="@value.Id">@value.AddressLine1, @value.City</option>}</select></label><label>Contact <input asp-for="Input.ShippingContactPerson" /></label><label>Telephone <input asp-for="Input.ShippingTelephone" /></label><label>Mobile <input asp-for="Input.ShippingMobile" /></label><label>Fax <input asp-for="Input.ShippingFax" /></label></fieldset>
<fieldset><legend>Billing</legend><label>Company <input asp-for="Input.BillingCompanyName" /></label><label>Address <select asp-for="Input.BillingAddressId"><option value="">Select an address</option>@foreach(var value in Model.Addresses){<option value="@value.Id">@value.AddressLine1, @value.City</option>}</select></label><label>Contact <input asp-for="Input.BillingContactPerson" /></label><label>Telephone <input asp-for="Input.BillingTelephone" /></label><label>Mobile <input asp-for="Input.BillingMobile" /></label><label>Fax <input asp-for="Input.BillingFax" /></label></fieldset></div>
<fieldset><legend>Order</legend><label>Ordered by <select asp-for="Input.EmployeeId"><option value="">Select an employee</option>@foreach(var value in Model.Employees){<option value="@value.Id">@value.FullName</option>}</select></label><div class="form-columns"><label>Shipping method <input asp-for="Input.ShippingMethod" /></label><label>FOB <input asp-for="Input.Fob" /></label><label>Terms <input asp-for="Input.Terms" /></label></div><label>Notes <textarea asp-for="Input.Notes" rows="5"></textarea></label></fieldset>
<fieldset><legend>Order items</legend><div id="order-items">@for(var index = 0; index < Model.Input.Items.Count; index++){<div class="order-item"><label>Part number <input asp-for="Input.Items[index].PartNumber" /></label><label>Description <input asp-for="Input.Items[index].Description" /></label><label>Unit price (THB) <input asp-for="Input.Items[index].UnitPrice" type="number" min="0" step="0.01" /></label><label>Quantity <input asp-for="Input.Items[index].Quantity" type="number" min="1" /></label></div>}</div><button type="button" id="add-item" class="secondary">Add line item</button></fieldset>
<button>Create, render and upload</button></form></section>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.getElementById('add-item').addEventListener('click',()=>{const host=document.getElementById('order-items');const i=host.children.length;const row=document.createElement('div');row.className='order-item';row.innerHTML=`<label>Part number <input name="Input.Items[${i}].PartNumber"></label><label>Description <input name="Input.Items[${i}].Description" required></label><label>Unit price (THB) <input name="Input.Items[${i}].UnitPrice" type="number" min="0" step="0.01" required></label><label>Quantity <input name="Input.Items[${i}].Quantity" type="number" min="1" value="1" required></label>`;host.appendChild(row);});</script> }
